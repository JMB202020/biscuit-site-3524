---
import '../styles/site.css';
const businessName = 'Birchwood Boarding Kennels';
const id = '3524';
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Contact | Birchwood Boarding Kennels | Bexley</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="preload" href="/3524/fonts/nunito-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/3524/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin />
  </head>
  <body class="bg-cream">

    <!-- Preview banner -->
    <div class="bg-brown text-white py-2.5 px-4 text-center text-sm sticky top-0 z-50">
      <div class="max-w-4xl mx-auto flex flex-col sm:flex-row items-center justify-center gap-2 sm:gap-4">
        <span>Preview redesign for <strong>Birchwood Boarding Kennels</strong> by <strong>Biscuit Web</strong></span>
        <a href={`https://biscuitweb.co.uk/activate?id=${id}&name=${encodeURIComponent(businessName)}`} class="inline-flex items-center px-4 py-1 bg-white text-brown font-bold text-xs rounded-full hover:opacity-80 transition-opacity shrink-0">
          Like it? Activate for £20/month
        </a>
      </div>
    </div>

    <!-- Nav -->
    <header class="bg-white border-b border-border sticky top-10 z-40">
      <div class="mx-auto max-w-7xl px-6 py-4 flex items-center justify-between">
        <a href="/3524" class="font-display font-extrabold text-xl text-forest leading-tight">
          🐾 Birchwood Kennels
        </a>
        <button
          class="md:hidden p-2 text-ink-soft"
          onclick="document.getElementById('mobile-nav-3524-con').classList.toggle('hidden')"
          aria-label="Open menu"
        >
          <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
        </button>
        <nav class="hidden md:flex items-center gap-8">
          <a href="/3524" class="text-sm text-ink-soft hover:text-forest font-semibold transition-colors">Home</a>
          <a href="/3524/services" class="text-sm text-ink-soft hover:text-forest font-semibold transition-colors">Services &amp; Prices</a>
          <a href="/3524/gallery" class="text-sm text-ink-soft hover:text-forest font-semibold transition-colors">Facilities</a>
          <a href="/3524/contact" class="text-sm text-forest font-semibold transition-colors">Contact</a>
          <a href="/3524/contact" class="inline-flex items-center px-5 py-2 bg-forest text-white font-display font-bold text-sm rounded-lg hover:bg-forest-deep transition-colors">
            Book a stay
          </a>
        </nav>
      </div>
      <nav id="mobile-nav-3524-con" class="hidden md:hidden bg-white border-t border-border px-6 pb-5 pt-4 space-y-3">
        <a href="/3524" class="block text-sm font-semibold text-ink-soft hover:text-forest">Home</a>
        <a href="/3524/services" class="block text-sm font-semibold text-ink-soft hover:text-forest">Services &amp; Prices</a>
        <a href="/3524/gallery" class="block text-sm font-semibold text-ink-soft hover:text-forest">Facilities</a>
        <a href="/3524/contact" class="block text-sm font-semibold text-forest">Contact</a>
        <a href="/3524/contact" class="block px-5 py-3 bg-forest text-white font-display font-bold text-sm rounded-lg text-center hover:bg-forest-deep transition-colors">
          Book a stay
        </a>
      </nav>
    </header>

    <!-- Page hero -->
    <section class="bg-forest py-16 lg:py-20">
      <div class="mx-auto max-w-4xl px-6 text-center">
        <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-sm font-semibold mb-6 bg-white/15 text-white/90">
          📍 Bexley
        </span>
        <h1 class="font-display font-extrabold text-3xl sm:text-5xl lg:text-6xl text-white leading-tight tracking-tight mb-5">
          Get in touch
        </h1>
        <p class="text-white/80 text-lg max-w-xl mx-auto">
          We'd love to hear from you. Ring us, message us on Facebook, or use the form below and we'll get back to you as soon as we can.
        </p>
      </div>
    </section>

    <!-- Contact section -->
    <section class="bg-cream py-20 lg:py-28">
      <div class="mx-auto max-w-7xl px-6">
        <div class="grid grid-cols-1 lg:grid-cols-[1fr_480px] gap-12 items-start">

          <!-- Contact details -->
          <div>
            <h2 class="font-display font-extrabold text-2xl text-ink mb-8">How to reach us</h2>

            <div class="space-y-5 mb-10">
              <!-- Phone -->
              <div class="bg-white rounded-xl p-6 border border-border flex gap-5 items-start">
                <div class="w-12 h-12 rounded-xl bg-sage-pale flex items-center justify-center text-2xl shrink-0">📞</div>
                <div>
                  <p class="font-semibold text-ink mb-1">Phone</p>
                  <a href="tel:01322631996" class="text-forest font-bold text-xl hover:underline">01322 631996</a>
                  <p class="text-ink-soft text-sm mt-1">Best way to reach us quickly. We aim to answer during the day.</p>
                </div>
              </div>

              <!-- Facebook -->
              <div class="bg-white rounded-xl p-6 border border-border flex gap-5 items-start">
                <div class="w-12 h-12 rounded-xl bg-sage-pale flex items-center justify-center text-2xl shrink-0">💬</div>
                <div>
                  <p class="font-semibold text-ink mb-1">Facebook</p>
                  <a href="https://www.facebook.com/birchwoodboardingkennels" class="text-forest font-bold hover:underline" target="_blank" rel="noopener noreferrer">
                    facebook.com/birchwoodboardingkennels
                  </a>
                  <p class="text-ink-soft text-sm mt-1">You can send us a message on Facebook if the phone is busy or you prefer to write.</p>
                </div>
              </div>

              <!-- Address -->
              <div class="bg-white rounded-xl p-6 border border-border flex gap-5 items-start">
                <div class="w-12 h-12 rounded-xl bg-sage-pale flex items-center justify-center text-2xl shrink-0">📍</div>
                <div>
                  <p class="font-semibold text-ink mb-1">Address</p>
                  <address class="not-italic text-forest font-bold">
                    115B Tile Kiln Ln<br />Bexley
                  </address>
                  <p class="text-ink-soft text-sm mt-1">We're easy to find. Give us a call if you need directions and we'll talk you in.</p>
                </div>
              </div>
            </div>

            <!-- What to mention -->
            <div class="bg-forest-deep rounded-xl p-7 text-white">
              <h3 class="font-display font-bold text-lg mb-4">When you get in touch, it helps to mention:</h3>
              <ul class="space-y-3 text-white/85 text-sm">
                <li class="flex items-start gap-3">
                  <span class="text-sage-light mt-0.5">•</span>
                  Your dog's name, breed, and age
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-sage-light mt-0.5">•</span>
                  The dates you need (drop-off and collection)
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-sage-light mt-0.5">•</span>
                  Whether it's day boarding or overnight
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-sage-light mt-0.5">•</span>
                  Any medical conditions or dietary requirements
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-sage-light mt-0.5">•</span>
                  Whether your dog's vaccinations are up to date
                </li>
              </ul>
            </div>
          </div>

          <!-- Contact form -->
          <div class="bg-white rounded-2xl border border-border p-8 shadow-sm">
            <h2 class="font-display font-extrabold text-2xl text-ink mb-2">Send us a message</h2>
            <p class="text-ink-soft text-sm mb-7">We'll get back to you as soon as we can, usually within 24 hours.</p>
            <form
              action="https://formspree.io/f/birchwood3524"
              method="POST"
              class="space-y-5"
            >
              <div>
                <label for="name" class="block text-sm font-semibold text-ink mb-1.5">Your name</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  placeholder="e.g. Sarah Jones"
                  class="w-full px-4 py-3 rounded-lg border border-border bg-cream text-ink placeholder:text-ink-whisper text-sm focus:outline-none focus:ring-2 focus:ring-forest/40 focus:border-forest"
                />
              </div>
              <div>
                <label for="phone" class="block text-sm font-semibold text-ink mb-1.5">Phone number</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  placeholder="e.g. 07700 000000"
                  class="w-full px-4 py-3 rounded-lg border border-border bg-cream text-ink placeholder:text-ink-whisper text-sm focus:outline-none focus:ring-2 focus:ring-forest/40 focus:border-forest"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-semibold text-ink mb-1.5">Email address</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  placeholder="e.g. sarah@example.com"
                  class="w-full px-4 py-3 rounded-lg border border-border bg-cream text-ink placeholder:text-ink-whisper text-sm focus:outline-none focus:ring-2 focus:ring-forest/40 focus:border-forest"
                />
              </div>
              <div>
                <label for="dog" class="block text-sm font-semibold text-ink mb-1.5">Dog's name and breed</label>
                <input
                  type="text"
                  id="dog"
                  name="dog"
                  placeholder="e.g. Max, Labrador, 3 years old"
                  class="w-full px-4 py-3 rounded-lg border border-border bg-cream text-ink placeholder:text-ink-whisper text-sm focus:outline-none focus:ring-2 focus:ring-forest/40 focus:border-forest"
                />
              </div>
              <div>
                <label for="dates" class="block text-sm font-semibold text-ink mb-1.5">Dates required</label>
                <input
                  type="text"
                  id="dates"
                  name="dates"
                  placeholder="e.g. 10 July to 17 July 2026"
                  class="w-full px-4 py-3 rounded-lg border border-border bg-cream text-ink placeholder:text-ink-whisper text-sm focus:outline-none focus:ring-2 focus:ring-forest/40 focus:border-forest"
                />
              </div>
              <div>
                <label for="message" class="block text-sm font-semibold text-ink mb-1.5">Anything else we should know?</label>
                <textarea
                  id="message"
                  name="message"
                  rows="4"
                  placeholder="Tell us about your dog, any dietary requirements, medical needs, or questions you have..."
                  class="w-full px-4 py-3 rounded-lg border border-border bg-cream text-ink placeholder:text-ink-whisper text-sm focus:outline-none focus:ring-2 focus:ring-forest/40 focus:border-forest resize-none"
                ></textarea>
              </div>
              <button
                type="submit"
                class="w-full px-6 py-4 bg-forest text-white font-display font-bold text-base rounded-lg hover:bg-forest-deep transition-colors"
              >
                Send message
              </button>
            </form>
          </div>

        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="bg-ink py-14">
      <div class="mx-auto max-w-7xl px-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-10 mb-10">
          <div>
            <p class="font-display font-extrabold text-xl text-white mb-3">🐾 Birchwood Boarding Kennels</p>
            <p class="text-ink-whisper text-sm leading-relaxed">
              Professional dog boarding in Bexley. Heated kennels, daily exercise, and genuine love for every dog in our care.
            </p>
          </div>
          <div>
            <p class="font-display font-bold text-white mb-4">Find us</p>
            <address class="not-italic text-ink-whisper text-sm space-y-2 leading-relaxed">
              <p>115B Tile Kiln Ln<br />Bexley</p>
              <p><a href="tel:01322631996" class="hover:text-white transition-colors">01322 631996</a></p>
              <p><a href="https://www.facebook.com/birchwoodboardingkennels" class="hover:text-white transition-colors" target="_blank" rel="noopener noreferrer">Facebook page</a></p>
            </address>
          </div>
          <div>
            <p class="font-display font-bold text-white mb-4">Pages</p>
            <nav class="space-y-2">
              <a href="/3524" class="block text-ink-whisper text-sm hover:text-white transition-colors">Home</a>
              <a href="/3524/services" class="block text-ink-whisper text-sm hover:text-white transition-colors">Services &amp; Prices</a>
              <a href="/3524/gallery" class="block text-ink-whisper text-sm hover:text-white transition-colors">Facilities</a>
              <a href="/3524/contact" class="block text-ink-whisper text-sm hover:text-white transition-colors">Contact</a>
            </nav>
          </div>
        </div>
        <div class="border-t border-white/10 pt-8 flex flex-col sm:flex-row justify-between gap-3">
          <p class="text-ink-whisper text-xs">&copy; 2026 Birchwood Boarding Kennels. All rights reserved.</p>
          <p class="text-ink-whisper text-xs">This is a sample site built by <a href="https://biscuitweb.co.uk" class="hover:text-white transition-colors">Biscuit Web</a> to showcase our work.</p>
        </div>
      </div>
    </footer>

  </body>
</html>
