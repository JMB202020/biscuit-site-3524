---
import '../styles/site.css';
const businessName = 'Birchwood Boarding Kennels';
const id = '3524';
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Services &amp; Prices | Birchwood Boarding Kennels | Bexley</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="preload" href="/3524/fonts/nunito-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/3524/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin />
  </head>
  <body class="bg-cream">

    <!-- Preview banner -->
    <div class="bg-brown text-white py-2.5 px-4 text-center text-sm sticky top-0 z-50">
      <div class="max-w-4xl mx-auto flex flex-col sm:flex-row items-center justify-center gap-2 sm:gap-4">
        <span>Preview redesign for <strong>Birchwood Boarding Kennels</strong> by <strong>Biscuit Web</strong></span>
        <a href={`https://biscuitweb.co.uk/activate?id=${id}&name=${encodeURIComponent(businessName)}`} class="inline-flex items-center px-4 py-1 bg-white text-brown font-bold text-xs rounded-full hover:opacity-80 transition-opacity shrink-0">
          Like it? Activate for £20/month
        </a>
      </div>
    </div>

    <!-- Nav -->
    <header class="bg-white border-b border-border sticky top-10 z-40">
      <div class="mx-auto max-w-7xl px-6 py-4 flex items-center justify-between">
        <a href="/3524" class="font-display font-extrabold text-xl text-forest leading-tight">
          🐾 Birchwood Kennels
        </a>
        <button
          class="md:hidden p-2 text-ink-soft"
          onclick="document.getElementById('mobile-nav-3524-svc').classList.toggle('hidden')"
          aria-label="Open menu"
        >
          <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
        </button>
        <nav class="hidden md:flex items-center gap-8">
          <a href="/3524" class="text-sm text-ink-soft hover:text-forest font-semibold transition-colors">Home</a>
          <a href="/3524/services" class="text-sm text-forest font-semibold transition-colors">Services &amp; Prices</a>
          <a href="/3524/gallery" class="text-sm text-ink-soft hover:text-forest font-semibold transition-colors">Facilities</a>
          <a href="/3524/contact" class="text-sm text-ink-soft hover:text-forest font-semibold transition-colors">Contact</a>
          <a href="/3524/contact" class="inline-flex items-center px-5 py-2 bg-forest text-white font-display font-bold text-sm rounded-lg hover:bg-forest-deep transition-colors">
            Book a stay
          </a>
        </nav>
      </div>
      <nav id="mobile-nav-3524-svc" class="hidden md:hidden bg-white border-t border-border px-6 pb-5 pt-4 space-y-3">
        <a href="/3524" class="block text-sm font-semibold text-ink-soft hover:text-forest">Home</a>
        <a href="/3524/services" class="block text-sm font-semibold text-forest">Services &amp; Prices</a>
        <a href="/3524/gallery" class="block text-sm font-semibold text-ink-soft hover:text-forest">Facilities</a>
        <a href="/3524/contact" class="block text-sm font-semibold text-ink-soft hover:text-forest">Contact</a>
        <a href="/3524/contact" class="block px-5 py-3 bg-forest text-white font-display font-bold text-sm rounded-lg text-center hover:bg-forest-deep transition-colors">
          Book a stay
        </a>
      </nav>
    </header>

    <!-- Page hero -->
    <section class="bg-forest py-16 lg:py-20">
      <div class="mx-auto max-w-4xl px-6 text-center">
        <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-sm font-semibold mb-6 bg-white/15 text-white/90">
          📍 Bexley
        </span>
        <h1 class="font-display font-extrabold text-3xl sm:text-5xl lg:text-6xl text-white leading-tight tracking-tight mb-5">
          Services &amp; pricing
        </h1>
        <p class="text-white/80 text-lg max-w-xl mx-auto">
          Everything we offer at Birchwood, clearly explained. Call us on <a href="tel:01322631996" class="underline text-white font-semibold">01322 631996</a> for a specific quote.
        </p>
      </div>
    </section>

    <!-- Main services -->
    <section class="bg-cream py-20 lg:py-28">
      <div class="mx-auto max-w-7xl px-6">
        <h2 class="font-display font-extrabold text-3xl text-ink mb-12 text-center">What we offer</h2>

        <!-- Day boarding -->
        <div class="bg-white rounded-2xl border border-border overflow-hidden mb-8">
          <div class="grid grid-cols-1 md:grid-cols-[auto_1fr] items-stretch">
            <div class="bg-sage-pale flex items-center justify-center p-10 md:px-14">
              <span class="text-6xl">🌞</span>
            </div>
            <div class="p-8 md:p-10">
              <h3 class="font-display font-extrabold text-2xl text-ink mb-3">Day boarding</h3>
              <p class="text-ink-soft leading-relaxed mb-5">
                Need somewhere for your dog while you're at work or out for the day? Drop your dog off in the morning and collect in the evening. They'll spend the day in their own kennel with access to an outdoor run, plus time in our exercise areas. It's a good option for dogs that aren't happy being left at home alone.
              </p>
              <ul class="text-ink-soft text-sm space-y-2 mb-6">
                <li class="flex items-center gap-2"><span class="text-forest font-bold">✓</span> Access to private outdoor run throughout the day</li>
                <li class="flex items-center gap-2"><span class="text-forest font-bold">✓</span> Exercise in our secure outdoor areas</li>
                <li class="flex items-center gap-2"><span class="text-forest font-bold">✓</span> Fed according to your dog's normal routine</li>
                <li class="flex items-center gap-2"><span class="text-forest font-bold">✓</span> Supervision throughout the day</li>
              </ul>
              <a href="/3524/contact" class="inline-flex items-center px-6 py-3 bg-forest text-white font-display font-bold text-sm rounded-lg hover:bg-forest-deep transition-colors">
                Enquire about day boarding
              </a>
            </div>
          </div>
        </div>

        <!-- Overnight boarding -->
        <div class="bg-white rounded-2xl border border-border overflow-hidden mb-8">
          <div class="grid grid-cols-1 md:grid-cols-[auto_1fr] items-stretch">
            <div class="bg-tan-light flex items-center justify-center p-10 md:px-14">
              <span class="text-6xl">🌙</span>
            </div>
            <div class="p-8 md:p-10">
              <div class="flex items-start justify-between flex-wrap gap-4 mb-3">
                <h3 class="font-display font-extrabold text-2xl text-ink">Overnight boarding</h3>
                <span class="inline-block px-4 py-1.5 bg-forest text-white text-xs font-bold rounded-full">Most popular</span>
              </div>
              <p class="text-ink-soft leading-relaxed mb-5">
                Our main service and the one most of our customers use. Your dog gets their own heated kennel with private outdoor run, plenty of exercise, and proper care right through until you come to collect them. We maintain your dog's existing feeding routine as closely as possible, so there's minimal disruption to their day.
              </p>
              <ul class="text-ink-soft text-sm space-y-2 mb-6">
                <li class="flex items-center gap-2"><span class="text-forest font-bold">✓</span> Heated individual kennel with bedding</li>
                <li class="flex items-center gap-2"><span class="text-forest font-bold">✓</span> Private outdoor run with access throughout the day</li>
                <li class="flex items-center gap-2"><span class="text-forest font-bold">✓</span> Exercise in our secure outdoor areas</li>
                <li class="flex items-center gap-2"><span class="text-forest font-bold">✓</span> Fed to your dog's existing schedule and portions</li>
                <li class="flex items-center gap-2"><span class="text-forest font-bold">✓</span> Evening checks to make sure your dog is settled</li>
              </ul>
              <a href="/3524/contact" class="inline-flex items-center px-6 py-3 bg-forest text-white font-display font-bold text-sm rounded-lg hover:bg-forest-deep transition-colors">
                Enquire about overnight boarding
              </a>
            </div>
          </div>
        </div>

        <!-- Extended stays -->
        <div class="bg-white rounded-2xl border border-border overflow-hidden mb-8">
          <div class="grid grid-cols-1 md:grid-cols-[auto_1fr] items-stretch">
            <div class="bg-cream-dark flex items-center justify-center p-10 md:px-14">
              <span class="text-6xl">📅</span>
            </div>
            <div class="p-8 md:p-10">
              <h3 class="font-display font-extrabold text-2xl text-ink mb-3">Extended stays (1+ weeks)</h3>
              <p class="text-ink-soft leading-relaxed mb-5">
                Going away on holiday or dealing with something that means you'll be away for a week or more? We accommodate longer stays and offer discounted rates for extended bookings. We find that most dogs settle into a nice routine after the first couple of days and are quite comfortable by the end of the week.
              </p>
              <ul class="text-ink-soft text-sm space-y-2 mb-6">
                <li class="flex items-center gap-2"><span class="text-forest font-bold">✓</span> All overnight boarding provisions included</li>
                <li class="flex items-center gap-2"><span class="text-forest font-bold">✓</span> Discounted rates for stays of a week or more</li>
                <li class="flex items-center gap-2"><span class="text-forest font-bold">✓</span> Consistent routine throughout the stay</li>
                <li class="flex items-center gap-2"><span class="text-forest font-bold">✓</span> We can administer regular medication with instructions</li>
              </ul>
              <a href="/3524/contact" class="inline-flex items-center px-6 py-3 bg-forest text-white font-display font-bold text-sm rounded-lg hover:bg-forest-deep transition-colors">
                Get a quote for a long stay
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Pricing note -->
    <section class="bg-forest-deep py-16">
      <div class="mx-auto max-w-3xl px-6 text-center">
        <h2 class="font-display font-extrabold text-2xl sm:text-3xl text-white mb-5">Getting a price</h2>
        <p class="text-white/80 text-lg leading-relaxed mb-8">
          Prices vary depending on your dog's size, the type of service, and the length of stay. We prefer to give you an accurate quote directly rather than publish rates that might not apply to your situation. Ring us on <strong class="text-white">01322 631996</strong> or drop us a message on Facebook and we'll get back to you promptly.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="tel:01322631996" class="inline-flex items-center justify-center px-8 py-4 bg-white text-forest font-display font-bold text-base rounded-lg hover:bg-cream transition-colors">
            📞 01322 631996
          </a>
          <a href="/3524/contact" class="inline-flex items-center justify-center px-8 py-4 border-2 border-white/50 text-white font-display font-bold text-base rounded-lg hover:border-white transition-colors">
            Send a message
          </a>
        </div>
      </div>
    </section>

    <!-- Requirements -->
    <section class="bg-cream-dark py-20">
      <div class="mx-auto max-w-4xl px-6">
        <h2 class="font-display font-extrabold text-3xl text-ink mb-8 text-center">Before you book</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <div class="bg-white rounded-xl p-7 border border-border">
            <div class="text-3xl mb-4">💉</div>
            <h3 class="font-display font-bold text-lg text-ink mb-2">Vaccinations required</h3>
            <p class="text-ink-soft text-sm leading-relaxed">
              All dogs must have up-to-date vaccinations. We ask to see vaccination records at drop-off, covering distemper, parvovirus, hepatitis, and leptospirosis at minimum. This is non-negotiable and protects every dog in our care.
            </p>
          </div>
          <div class="bg-white rounded-xl p-7 border border-border">
            <div class="text-3xl mb-4">🐕</div>
            <h3 class="font-display font-bold text-lg text-ink mb-2">Temperament</h3>
            <p class="text-ink-soft text-sm leading-relaxed">
              We welcome dogs of all sizes and most breeds. If your dog has any behavioural considerations or has not been in a kennel environment before, just let us know when you enquire and we'll have an honest conversation about whether we're the right fit.
            </p>
          </div>
          <div class="bg-white rounded-xl p-7 border border-border">
            <div class="text-3xl mb-4">🏥</div>
            <h3 class="font-display font-bold text-lg text-ink mb-2">Health conditions</h3>
            <p class="text-ink-soft text-sm leading-relaxed">
              Please let us know about any health conditions, allergies, or medication requirements when you book. We can administer medication with clear written instructions from you, and we'll flag anything unusual straight away.
            </p>
          </div>
          <div class="bg-white rounded-xl p-7 border border-border">
            <div class="text-3xl mb-4">📞</div>
            <h3 class="font-display font-bold text-lg text-ink mb-2">Book early</h3>
            <p class="text-ink-soft text-sm leading-relaxed">
              We get very busy at bank holidays, school half-terms, and over the summer and Christmas periods. We recommend booking as far in advance as possible to secure your dates, particularly for overnight and longer stays.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="bg-ink py-14">
      <div class="mx-auto max-w-7xl px-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-10 mb-10">
          <div>
            <p class="font-display font-extrabold text-xl text-white mb-3">🐾 Birchwood Boarding Kennels</p>
            <p class="text-ink-whisper text-sm leading-relaxed">
              Professional dog boarding in Bexley. Heated kennels, daily exercise, and genuine love for every dog in our care.
            </p>
          </div>
          <div>
            <p class="font-display font-bold text-white mb-4">Find us</p>
            <address class="not-italic text-ink-whisper text-sm space-y-2 leading-relaxed">
              <p>115B Tile Kiln Ln<br />Bexley</p>
              <p><a href="tel:01322631996" class="hover:text-white transition-colors">01322 631996</a></p>
              <p><a href="https://www.facebook.com/birchwoodboardingkennels" class="hover:text-white transition-colors" target="_blank" rel="noopener noreferrer">Facebook page</a></p>
            </address>
          </div>
          <div>
            <p class="font-display font-bold text-white mb-4">Pages</p>
            <nav class="space-y-2">
              <a href="/3524" class="block text-ink-whisper text-sm hover:text-white transition-colors">Home</a>
              <a href="/3524/services" class="block text-ink-whisper text-sm hover:text-white transition-colors">Services &amp; Prices</a>
              <a href="/3524/gallery" class="block text-ink-whisper text-sm hover:text-white transition-colors">Facilities</a>
              <a href="/3524/contact" class="block text-ink-whisper text-sm hover:text-white transition-colors">Contact</a>
            </nav>
          </div>
        </div>
        <div class="border-t border-white/10 pt-8 flex flex-col sm:flex-row justify-between gap-3">
          <p class="text-ink-whisper text-xs">&copy; 2026 Birchwood Boarding Kennels. All rights reserved.</p>
          <p class="text-ink-whisper text-xs">This is a sample site built by <a href="https://biscuitweb.co.uk" class="hover:text-white transition-colors">Biscuit Web</a> to showcase our work.</p>
        </div>
      </div>
    </footer>

  </body>
</html>
